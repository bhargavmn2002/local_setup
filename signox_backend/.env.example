# Database Configuration (required — app will not work without a reachable MongoDB)
# Atlas example:
DATABASE_URL="mongodb+srv://signox_admin:Signox_Admin@cluster1.vpmjsw3.mongodb.net/signox_db?retryWrites=true&w=majority&appName=Cluster1"# Local example (MongoDB Community):
# DATABASE_URL="mongodb://127.0.0.1:27017/signox"

# Security
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters
MAX_LOGIN_ATTEMPTS=50
LOCKOUT_TIME=900000

# Server Configuration
PORT=5000
HOST=0.0.0.0
NODE_ENV=production

# CORS Configuration (comma-separated origins; include www if you still serve it)
CORS_ORIGIN=https://signoxcms.com,https://www.signoxcms.com

# Timezone
TIMEZONE=Asia/Kolkata

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=200

# HTTPS Configuration (optional)
ENABLE_HTTPS=false
SSL_KEY_PATH=/path/to/ssl/key.pem
SSL_CERT_PATH=/path/to/ssl/cert.pem
HTTPS_PORT=5443

# AWS S3 Configuration (optional)
USE_S3_FOR_PLAYER_APPS=false
# CMS media library: upload to S3 instead of public/uploads (set true in production)
USE_S3_FOR_MEDIA=false
# Object key prefix inside the bucket (no leading/trailing slashes)
AWS_S3_MEDIA_PREFIX=media
# Optional: CloudFront or custom domain base URL for public objects (no trailing slash)
# AWS_S3_PUBLIC_BASE_URL=https://dxxxxxxxx.cloudfront.net
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=signox-media-prod